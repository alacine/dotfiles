# macOS-only Ghostty config

# Font (Monaco as primary, LXGW WenKai as CJK fallback, no italic)
font-family = Monaco
font-family = LXGW WenKai
font-style = Regular
font-family-bold = Monaco
font-family-bold = LXGW WenKai
font-style-bold = Bold
font-family-italic = Monaco
font-family-italic = LXGW WenKai
font-style-italic = Regular
font-family-bold-italic = Monaco
font-family-bold-italic = LXGW WenKai
font-style-bold-italic = Bold

# Use Option as Alt (recommended for terminal apps). Disable if you need
# the native macOS Option-based Unicode input behavior.
macos-option-as-alt = true

# Swap Command (Super) and Control inside Ghostty.
# Note: macOS menu shortcuts are handled before Ghostty.
key-remap = super=ctrl
key-remap = ctrl=super

# Copy/paste
keybind = super+shift+c=copy_to_clipboard
keybind = super+shift+v=paste_from_clipboard

# Explicitly override macOS menu shortcuts that conflict with key-remap.
# These cmd+key bindings send the corresponding ctrl+key character directly,
# taking priority over Ghostty's own menu items (e.g. cmd+d = split right).
keybind = super+a=text:\x01
keybind = super+b=text:\x02
keybind = super+c=text:\x03
keybind = super+d=text:\x04
keybind = super+e=text:\x05
keybind = super+f=text:\x06
keybind = super+g=text:\x07
keybind = super+h=text:\x08
keybind = super+i=text:\x09
keybind = super+j=text:\x0a
keybind = super+k=text:\x0b
keybind = super+l=text:\x0c
keybind = super+m=text:\x0d
keybind = super+n=text:\x0e
keybind = super+o=text:\x0f
keybind = super+p=text:\x10
keybind = super+q=text:\x11
keybind = super+r=text:\x12
keybind = super+s=text:\x13
keybind = super+t=text:\x14
keybind = super+u=text:\x15
keybind = super+v=text:\x16
keybind = super+w=text:\x17
keybind = super+x=text:\x18
keybind = super+y=text:\x19
keybind = super+z=text:\x1a
