# Maintainer: alacine
pkgbase=alacine-aur-packages
pkgname=('alacine-aur-cli' 'alacine-aur-gui')
pkgver=1
pkgrel=1
arch=('any')
license=('custom')

_aur_cli_depends=(
    ## Dev Tools
    'neovim-remote' 'eww-wayland' 'debtap' 'sipcalc'
    'wrk' 'whatweb' 'vagrant' 'watchdog' 'weylus-bin'

    ## AI / Editors
    'claude-code' 'cursor-bin-patched' 'visual-studio-code-bin'
    'codex-app-bin' 'opencode-bin'

    ## CLI Fun
    'cbonsai' 'rbonsai' 'pipes.sh' 'shell-color-scripts-git'
    'tmux-xpanes' 'neofetch'

    ## System Tools
    'brillo' 'libinput-gestures' 'clipse'
    'asciinema-agg' 'gotop-bin'
)

_aur_desktop_depends=(
    'alacine-aur-cli'

    ## Proxy / VPN
    'clash-party-bin' 'clash-verge-rev-bin'

    ## Chinese Apps
    'wechat-bin' 'wemeet-wayland-screenshare-git' 'linuxqq-nt-bwrap'
    'netease-cloud-music' 'spotifox' 'z-library-bin'

    ## Editors / IDE
    'typora'

    ## Fonts
    'ttf-symbola'
    'ttf-wps-fonts'
    'noto-color-emoji-fontconfig'

    ## System Tools
    'blueberry' 'wl-color-picker'

    ## Apps
    'genymotion' 'google-chrome' 'slack-desktop'
    'remix-desktop' 'puffin'

    ## Finance
    'hledger-web-bin'
    'paisa-bin'

    ## Theme
    'vimix-gtk-themes-git'

    ## Misc
    'kd-bin' 'youtube-dl'
)

package_alacine-aur-cli() {
    pkgdesc="Personal AUR CLI packages"
    depends=("${_aur_cli_depends[@]}")
}

package_alacine-aur-gui() {
    pkgdesc="Personal AUR desktop packages"
    depends=("${_aur_desktop_depends[@]}")
}
